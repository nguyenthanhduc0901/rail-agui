GEMINI_API_KEY=your-gemini-api-key-here

# Optional: enable request-level runtime debug logs in Next.js server console
COPILOT_DEBUG=0

# Optional: LangSmith tracing (recommended for prompt/tool flow inspection)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=rail-agui

# Optional: log backend tool invocations in agent console
AGENT_TOOL_DEBUG=0
